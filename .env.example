# Postgres (used by docker-compose)
POSTGRES_USER=microlearn
POSTGRES_PASSWORD=microlearn
POSTGRES_DB=microlearn

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Backend
DATABASE_URL=postgresql://microlearn:microlearn@postgres:5432/microlearn
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
PORT=4000
UPLOAD_DIR=/app/uploads
MAX_IMAGE_SIZE_MB=2
MAX_VIDEO_SIZE_MB=500
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM="MicroLearn <no-reply@microlearn.local>"
CLIENT_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
